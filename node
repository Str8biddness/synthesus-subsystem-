#!/bin/bash
echo "🌌 AIVM Planetary OS - Resource Node Extension 🌌"
MASTER_IP="${1:-192.168.68.56}"
NODE_INDEX="${2:-1}"

echo "🔄 Connecting to Master Node at $MASTER_IP..."
# Restart local daemon as worker (if applicable)
systemctl restart aivm-daemon 2>/dev/null || true

echo "📺 Launching Contiguous SOS Desktop..."
export DISPLAY=:0

# 🚀 Start Peripheral Sync Listener (Kill any existing instance first)
pkill -f cluster_node
if [ -f "/opt/synthesus/cluster_node" ]; then
    nohup /opt/synthesus/cluster_node > /tmp/cluster_node.log 2>&1 &
    echo "📡 Native Hardware Peripheral Listener Active on Port 7878"
fi

if command -v google-chrome &> /dev/null; then
    google-chrome --app="http://$MASTER_IP:8080/?mode=worker&node_index=$NODE_INDEX" --start-fullscreen &
elif command -v chromium &> /dev/null; then
    chromium --app="http://$MASTER_IP:8080/?mode=worker&node_index=$NODE_INDEX" --start-fullscreen &
elif command -v firefox &> /dev/null; then
    firefox -kiosk "http://$MASTER_IP:8080/?mode=worker&node_index=$NODE_INDEX" &
else
    xdg-open "http://$MASTER_IP:8080/?mode=worker&node_index=$NODE_INDEX" &
fi

echo "✨ Merged into God-Mode Cluster as Resource Node."
