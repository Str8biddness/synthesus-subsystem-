#!/bin/bash
echo "🌌 AIVM Planetary OS - Resource Node Extension 🌌"
if [[ "$1" == *.* ]]; then
    MASTER_IP="$1"
    NODE_INDEX="${2:-1}"
else
    MASTER_IP="192.168.68.56"
    NODE_INDEX="${1:-1}"
fi

echo "🔄 Connecting to Master Node at $MASTER_IP..."
# Restart local daemon as worker (if applicable)
systemctl restart aivm-daemon 2>/dev/null || true

echo "📺 Launching Contiguous SOS Desktop..."
export DISPLAY=:0

if command -v google-chrome &> /dev/null; then
    nohup google-chrome --app="http://$MASTER_IP:8080/?mode=worker&node_index=$NODE_INDEX" --start-fullscreen >/dev/null 2>&1 &
elif command -v chromium &> /dev/null; then
    nohup chromium --app="http://$MASTER_IP:8080/?mode=worker&node_index=$NODE_INDEX" --start-fullscreen >/dev/null 2>&1 &
elif command -v firefox &> /dev/null; then
    nohup firefox -kiosk "http://$MASTER_IP:8080/?mode=worker&node_index=$NODE_INDEX" >/dev/null 2>&1 &
else
    nohup xdg-open "http://$MASTER_IP:8080/?mode=worker&node_index=$NODE_INDEX" >/dev/null 2>&1 &
fi

echo "✨ Merged into God-Mode Cluster as Resource Node."
